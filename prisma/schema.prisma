generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String          @id @default(cuid())
  name         String
  email        String          @unique
  passwordHash String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  guestRooms   GameRoom[]      @relation("GuestRooms")
  hostedRooms  GameRoom[]      @relation("HostRooms")
  kits         PrereleaseKit[]
}

model Card {
  id              String          @id @default(cuid())
  name            String
  scryfallId      String          @unique
  rarity          Rarity
  set             String
  colors          Json
  cmc             Int
  typeLine        String
  imagePath       String
  collectorNumber String
  manaCost        String?
  setName         String?
  oracleText      String?
  flavorText      String?
  power           String?
  toughness       String?
  loyalty         String?
  artist          String?
  releasedAt      String?
  rawData         Json?
  isToken         Boolean         @default(false)
  placedCards     PlacedCard[]
  promoInKits     PrereleaseKit[] @relation("PromoCard")

  @@index([isToken, name])
  @@index([set])
  @@index([name])
}

model PrereleaseKit {
  id          String       @id @default(cuid())
  college     College
  createdAt   DateTime     @default(now())
  promoCardId String?
  userId      String?

  guestRooms  GameRoom[]   @relation("GuestKit")
  hostedRooms GameRoom[]   @relation("HostKit")
  placedCards PlacedCard[]
  promoCard   Card?        @relation("PromoCard", fields: [promoCardId], references: [id])
  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

model GameRoom {
  id            String         @id @default(cuid())
  status        GameRoomStatus @default(WAITING)
  stateVersion  Int            @default(0)
  hostUserId    String
  hostKitId     String?
  hostPlayerId  String?
  hostReady     Boolean        @default(false)
  guestUserId   String?
  guestKitId    String?
  guestPlayerId String?
  guestReady    Boolean        @default(false)
  gameState     Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  guestKit      PrereleaseKit? @relation("GuestKit", fields: [guestKitId], references: [id])
  guestUser     User?          @relation("GuestRooms", fields: [guestUserId], references: [id])
  hostKit       PrereleaseKit? @relation("HostKit", fields: [hostKitId], references: [id])
  hostUser      User           @relation("HostRooms", fields: [hostUserId], references: [id])

  @@index([hostUserId])
  @@index([guestUserId])
  @@index([hostKitId])
  @@index([guestKitId])
  @@index([status])
}

model PlacedCard {
  id         String        @id @default(cuid())
  cardId     String
  kitId      String
  posX       Float         @default(0)
  posY       Float         @default(0)
  zIndex     Int           @default(0)
  isMainDeck Boolean?
  isFoil     Boolean       @default(false)
  card       Card          @relation(fields: [cardId], references: [id])
  kit        PrereleaseKit @relation(fields: [kitId], references: [id])

  @@index([kitId])
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  MYTHIC
}

enum CardSet {
  SOS
  SOA
  SPG
}

enum College {
  LOREHOLD
  PRISMARI
  QUANDRIX
  SILVERQUILL
  WITHERBLOOM
}

enum GameRoomStatus {
  WAITING
  LOBBY
  READY
  ACTIVE
  FINISHED
}
