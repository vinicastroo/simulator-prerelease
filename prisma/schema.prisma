// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  MYTHIC
}

enum CardSet {
  SOS
  SOA
  SPG
}

enum College {
  LOREHOLD
  PRISMARI
  QUANDRIX
  SILVERQUILL
  WITHERBLOOM
}

model User {
  id           String          @id @default(cuid())
  name         String
  email        String          @unique
  passwordHash String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  kits         PrereleaseKit[]
}

model Card {
  id              String          @id @default(cuid())
  name            String
  scryfallId      String          @unique
  rarity          Rarity
  set             String
  setName         String?
  colors          Json
  manaCost        String?
  cmc             Int
  typeLine        String
  oracleText      String?
  flavorText      String?
  power           String?
  toughness       String?
  loyalty         String?
  artist          String?
  releasedAt      String?
  imagePath       String
  collectorNumber String
  rawData         Json?
  placedCards     PlacedCard[]
  promoInKits     PrereleaseKit[] @relation("PromoCard")
}

model PrereleaseKit {
  id          String       @id @default(cuid())
  userId      String?
  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  college     College
  createdAt   DateTime     @default(now())
  promoCardId String?
   promoCard   Card?        @relation("PromoCard", fields: [promoCardId], references: [id])
   placedCards PlacedCard[]
}

model PlacedCard {
  id         String        @id @default(cuid())
  card       Card          @relation(fields: [cardId], references: [id])
  cardId     String
  kit        PrereleaseKit @relation(fields: [kitId], references: [id])
  kitId      String
  posX       Float         @default(0)
  posY       Float         @default(0)
  zIndex     Int           @default(0)
  isMainDeck Boolean?      // null = on canvas only, true = main deck, false = sideboard
  isFoil     Boolean       @default(false)
}
